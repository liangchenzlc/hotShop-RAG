APP_NAME=HotSpotRAG
APP_VERSION=0.1.0
APP_ENV=dev

MYSQL_URL=mysql+pymysql://root:root@127.0.0.1:3306/hotspot_rag?charset=utf8mb4

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hotspot-rag
MINIO_SECURE=false

MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION=hotspot_chunks

EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_MODEL=text-embedding-3-small
CHAT_PROVIDER=openai_compatible
CHAT_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace_me

SCHEDULER_ENABLED=true
SCHEDULER_CRON=*/30 * * * *
FETCH_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
WORKFLOW_INTENT_LOW_CONFIDENCE_THRESHOLD=0.65
